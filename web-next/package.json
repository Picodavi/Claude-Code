{
  "name": "web-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run lib",
    "serve:out": "node scripts/serve-static.mjs out 4173",
    "test:e2e": "npm run build && playwright test --project=chromium --project=firefox --project=webkit --project=mobile-chrome --project=mobile-safari",
    "test:e2e:quick": "playwright test --project=chromium --project=firefox --project=webkit --project=mobile-chrome --project=mobile-safari",
    "test:e2e:firefox": "playwright test e2e/firefox-hero.spec.ts --project=firefox",
    "test:e2e:edge": "playwright test --project=edge",
    "test:performance": "node scripts/run-performance.mjs",
    "test:performance:strict": "node scripts/run-performance.mjs --strict",
    "test:a11y": "playwright test e2e/accessibility.spec.ts --project=chromium --project=firefox --project=webkit",
    "audit:security": "npm audit --audit-level=high",
    "audit:full": "npm run lint && npm run typecheck && npm test && npm run test:e2e"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-three/fiber": "^9.6.1",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
